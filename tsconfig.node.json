{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.js", "vite.config.ts"]
}
